# wrangler.toml — copy to wrangler.toml and customize
# Deploy with: wrangler deploy
# Set secret with: wrangler secret put RAG_WORKER_SECRET

name = "accent-rag"
main = "embed-worker.js"
compatibility_date = "2026-04-01"
workers_dev = true

[ai]
binding = "AI"

[vars]
ALLOWED_ORIGINS = "https://accent-os.pages.dev,https://accent-os-staging.pages.dev,http://localhost:8788"

# Free Workers AI quota (as of 2026): 10K Neurons/day; bge-base-en-v1.5 ≈ 0.04 Neurons/embed.
# That's ~250K free embeddings per day — plenty for AccentOS scale.
