{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brainstorm-build-handoff/01-concept",
  "title": "Concept Extraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "true_objective",
    "system_category",
    "primary_executor",
    "operational_goals",
    "implied_workflows",
    "hidden_assumptions",
    "constraints",
    "non_goals"
  ],
  "properties": {
    "true_objective": {
      "type": "string",
      "description": "Single sentence — the system's reason to exist.",
      "minLength": 10,
      "maxLength": 240
    },
    "system_category": {
      "type": "string",
      "enum": ["workflow", "orchestration", "agent", "infra", "schema", "tool"]
    },
    "primary_executor": {
      "type": "string",
      "enum": ["claude-code", "codex", "engineer", "autonomous-agent", "mixed"]
    },
    "operational_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "implied_workflows": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 }
    },
    "hidden_assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  }
}
