{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brainstorm-build-handoff/06-build-plan",
  "title": "Build Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "directory_structure",
    "schemas",
    "implementation_phases",
    "validation_gates",
    "operating_rules",
    "next_phases"
  ],
  "properties": {
    "directory_structure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "purpose"],
        "additionalProperties": false,
        "properties": { "path": {"type":"string"}, "purpose": {"type":"string"} }
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "owner_phase", "format"],
        "additionalProperties": false,
        "properties": {
          "name":        { "type": "string" },
          "owner_phase": { "type": "string" },
          "format":      { "type": "string", "enum": ["json-schema", "yaml", "markdown", "typescript", "none"] }
        }
      }
    },
    "implementation_phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "outputs", "depends_on", "validation"],
        "additionalProperties": false,
        "properties": {
          "id":         { "type": "string", "pattern": "^P[0-9]+$" },
          "title":      { "type": "string" },
          "outputs":    { "type": "array", "minItems": 1, "items": {"type":"string"} },
          "depends_on": { "type": "array", "items": {"type":"string", "pattern": "^P[0-9]+$"} },
          "validation": { "type": "string" }
        }
      }
    },
    "validation_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gate", "applies_to", "passes_if"],
        "additionalProperties": false,
        "properties": {
          "gate":       { "type": "string" },
          "applies_to": { "type": "string" },
          "passes_if":  { "type": "string" }
        }
      }
    },
    "operating_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "next_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trigger", "scope"],
        "additionalProperties": false,
        "properties": {
          "trigger": { "type": "string" },
          "scope":   { "type": "string" }
        }
      }
    }
  }
}
