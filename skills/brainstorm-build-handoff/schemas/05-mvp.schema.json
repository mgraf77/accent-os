{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brainstorm-build-handoff/05-mvp",
  "title": "MVP Reduction",
  "type": "object",
  "additionalProperties": false,
  "required": ["must_build", "defer", "delete", "future_hooks", "scope_boundary"],
  "properties": {
    "must_build": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item", "phase_ref", "reason"],
        "additionalProperties": false,
        "properties": {
          "item":      { "type": "string" },
          "phase_ref": { "type": "string", "description": "Pointer to a key in 02-systems.json" },
          "reason":    { "type": "string" }
        }
      }
    },
    "defer": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "until", "reason"],
        "additionalProperties": false,
        "properties": {
          "item":   { "type": "string" },
          "until":  { "type": "string", "description": "Trigger condition for revisiting" },
          "reason": { "type": "string" }
        }
      }
    },
    "delete": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "reason"],
        "additionalProperties": false,
        "properties": {
          "item":   { "type": "string" },
          "reason": { "type": "string", "enum": ["scope creep", "speculation", "duplicate", "premature abstraction"] }
        }
      }
    },
    "future_hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["surface", "extension_point", "rationale"],
        "additionalProperties": false,
        "properties": {
          "surface":         { "type": "string" },
          "extension_point": { "type": "string" },
          "rationale":       { "type": "string" }
        }
      }
    },
    "scope_boundary": {
      "type": "string",
      "description": "Single sentence — the deterministic done-criterion.",
      "minLength": 10,
      "maxLength": 240
    }
  }
}
